<?xml version="1.0" encoding="UTF-8"?>
<!--
  HeelonVault Windows Installer (WiX v4 / wix.exe) - GTK4 Edition
  ─────────────────────────────────────────────────────────────────
  Structure:
    wix/main.wxs   – Static product/directory/feature declaration
    wix/dlls.wxs   – Generated at CI build-time by scripts/collect-dlls.sh
                     Contains one <Component> per DLL identified by ntldd
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package
    Name="HeelonVault"
    Version="$(var.ProductVersion)"
    Manufacturer="Heelonys"
    UpgradeCode="4F2D8A1C-3B7E-4F9A-8C5D-2E6F1A0B3C4D"
    Language="1033"
    Codepage="1252"
    InstallerVersion="500"
    Compressed="yes">

    <!-- Allow clean upgrade: remove previous version before install -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of HeelonVault is already installed."
      Schedule="afterInstallInitialize" />

    <MediaTemplate EmbedCab="yes" CompressionLevel="mszip" />

    <!-- ── Directory tree ────────────────────────────────────────────── -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="HeelonVault">
        <!-- GLib runtime resources -->
        <Directory Id="SCHEMAFOLDER" Name="share">
          <Directory Id="GLIBSCHEMAFOLDER" Name="glib-2.0">
            <Directory Id="SCHEMASUBFOLDER" Name="schemas" />
          </Directory>
          <!-- GTK4 Theme -->
          <Directory Id="THEMESFOLDER" Name="themes">
            <Directory Id="ADWAITAFOLDER" Name="Adwaita" />
          </Directory>
          <!-- GTK4 Icons -->
          <Directory Id="ICONSFOLDER" Name="icons">
            <Directory Id="ADWAITAICONSFOLDER" Name="Adwaita" />
          </Directory>
        </Directory>
        <!-- GDK-Pixbuf (still required for GTK4 compatibility) -->
        <Directory Id="GDKPIXBUFFOLDER" Name="lib">
          <Directory Id="GDKPIXBUF2FOLDER" Name="gdk-pixbuf-2.0">
            <Directory Id="GDKPIXBUF_LOADERS" Name="2.10.0">
              <Directory Id="GDKPIXBUF_LOADERS_DIR" Name="loaders" />
            </Directory>
          </Directory>
        </Directory>
        <!-- répertoire et composants migrations -->
        <!-- Dans l'arbre de répertoires, après GDKPIXBUFFOLDER : -->
        <Directory Id="MIGRATIONSFOLDER" Name="migrations" />
        <!-- Nouveau ComponentGroup avant </Package> : -->
        <ComponentGroup Id="MigrationsComponents" Directory="MIGRATIONSFOLDER">
          <Component Id="Mig_0001" Guid="*"><File Source="wix\staging\migrations\0001_init_schema.sql" KeyPath="yes" /></Component>
          <Component Id="Mig_0002" Guid="*"><File Source="wix\staging\migrations\0002_db_metadata_schema_version.sql" KeyPath="yes" /></Component>
          <Component Id="Mig_0003" Guid="*"><File Source="wix\staging\migrations\0003_secret_item_extensions.sql" KeyPath="yes" /></Component>
          <Component Id="Mig_0004" Guid="*"><File Source="wix\staging\migrations\0004_user_profile_fields.sql" KeyPath="yes" /></Component>
          <Component Id="Mig_0005" Guid="*"><File Source="wix\staging\migrations\0005_auth_policy.sql" KeyPath="yes" /></Component>
          <Component Id="Mig_0006" Guid="*"><File Source="wix\staging\migrations\0006_auth_policy_auto_lock_delay.sql" KeyPath="yes" /></Component>
          <Component Id="Mig_0007" Guid="*"><File Source="wix\staging\migrations\0007_login_history.sql" KeyPath="yes" /></Component>
          <Component Id="Mig_0008" Guid="*"><File Source="wix\staging\migrations\0008_user_show_passwords_in_edit.sql" KeyPath="yes" /></Component>
          <Component Id="Mig_0009" Guid="*"><File Source="wix\staging\migrations\0009_user_totp_secret.sql" KeyPath="yes" /></Component>
          <Component Id="Mig_0010" Guid="*"><File Source="wix\staging\migrations\0010_user_preferred_language.sql" KeyPath="yes" /></Component>
          <Component Id="Mig_0011" Guid="*"><File Source="wix\staging\migrations\0011_teams.sql" KeyPath="yes" /></Component>
          <Component Id="Mig_0012" Guid="*"><File Source="wix\staging\migrations\0012_vault_key_shares.sql" KeyPath="yes" /></Component>
          <Component Id="Mig_0013" Guid="*"><File Source="wix\staging\migrations\0013_audit_log.sql" KeyPath="yes" /></Component>
          <Component Id="Mig_0014" Guid="*"><File Source="wix\staging\migrations\0014_vault_security_rbac.sql" KeyPath="yes" /></Component>
          <Component Id="Mig_0015" Guid="*"><File Source="wix\staging\migrations\0015_vault_sort_order.sql" KeyPath="yes" /></Component>
          <Component Id="Mig_0016" Guid="*"><File Source="wix\staging\migrations\0016_ip_rate_limiting.sql" KeyPath="yes" /></Component>
        </ComponentGroup>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="HeelonVault" />
    </StandardDirectory>

    <!-- ── Main executable component ────────────────────────────────── -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <File Id="heelonvault_exe"
              Source="target\x86_64-pc-windows-gnu\release\heelonvault.exe"
              KeyPath="yes" />
      </Component>

      <!-- GLib compiled schemas (required for GTK4) -->
      <Component Id="GLibSchemas" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <File Id="gschemas_compiled"
              Source="wix\staging\share\glib-2.0\schemas\gschemas.compiled"
              KeyPath="yes" />
      </Component>

      <!-- GDK-Pixbuf loaders.cache (still required for GTK4 compatibility) -->
      <Component Id="GdkPixbufLoaderCache" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
        <File Id="loaders_cache"
              Source="wix\staging\lib\gdk-pixbuf-2.0\2.10.0\loaders.cache"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ── GTK4 Theme Components ──────────────────────────────────── -->
    <ComponentGroup Id="GTK4ThemeComponents" Directory="THEMESFOLDER">
    </ComponentGroup>

    <!-- ── DLL components (generated into wix/dlls.wxs by CI) ────────── -->
    <!-- ComponentGroup Id="DllComponents" is declared in wix/dlls.wxs -->

    <!-- ── GDK-Pixbuf loader DLLs (generated into wix/dlls.wxs by CI) ──── -->
    <!-- ComponentGroup Id="PixbufLoaderComponents" in wix/dlls.wxs -->

    <!-- ── Start Menu shortcut ───────────────────────────────────────── -->
    <ComponentGroup Id="ShortcutComponents" Directory="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcut" Guid="D4E5F6A7-B8C9-0123-DEF0-234567890123">
        <Shortcut Id="AppShortcut"
                  Name="HeelonVault"
                  Description="HeelonVault Password &amp; Secret Manager"
                  Target="[INSTALLFOLDER]heelonvault.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="heelonvault.ico" />
        <RemoveFolder Id="RemoveProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\HeelonVault"
                       Name="StartMenuShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ── Icon ─────────────────────────────────────────────────────── -->
    <Icon Id="heelonvault.ico" SourceFile="wix\staging\heelonvault.ico" />

    <!-- ── Feature tree ─────────────────────────────────────────────── -->
    <Feature Id="ProductFeature" Title="HeelonVault" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="DllComponents" />
      <ComponentGroupRef Id="PixbufLoaderComponents" />
      <ComponentGroupRef Id="GTK4ThemeComponents" /> <!-- Ajout du thème GTK4 -->
      <ComponentGroupRef Id="ShortcutComponents" />
      <ComponentGroupRef Id="MigrationsComponents" />
    </Feature>

  </Package>
</Wix>